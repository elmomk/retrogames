// ---- OVERLAP HELPER ----
def overlaps(ax, ay, aw, ah, bx, by, bw, bh) {
    return ax < bx + bw && ax + aw > bx && ay < by + bh && ay + ah > by
}

// ---- CLEAR ALL DYNAMIC ARRAYS ----
def clearArrays() {
    platType.clear()
    platX.clear()
    platY.clear()
    platW.clear()
    platH.clear()

    eneType.clear()
    eneX.clear()
    eneY.clear()
    eneW.clear()
    eneH.clear()
    eneVx.clear()
    eneVy.clear()
    eneStartX.clear()
    eneRange.clear()
    eneShoot.clear()

    bulX.clear()
    bulY.clear()
