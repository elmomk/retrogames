// ---- DRAW SPRITE HELPERS ----
// Renders 8x8 pixel art by drawing one rectangle per non-transparent pixel.
// ch is extracted via substr(col, 1) for reliable ChaiScript string indexing.
def drawSprite(art, colors, sx, sy, scale) {
    for (var row = 0; row < art.size(); ++row) {
        var line = art[row]
        for (var col = 0; col < line.size(); ++col) {
            var ch = line.substr(col, 1)
            if (ch != ".") {
                var idx = to_int(ch) - 1
                if (idx >= 0 && idx < colors.size()) {
                    var c = colors[idx]
                    love.graphics.setColor(c[0], c[1], c[2])
                    love.graphics.rectangle("fill", sx + col * scale, sy + row * scale, scale, scale)
                }
            }
        }
    }
}

def drawSpriteFlipped(art, colors, sx, sy, scale) {
    var aw = art[0].size()
    for (var row = 0; row < art.size(); ++row) {
        var line = art[row]
        for (var col = 0; col < line.size(); ++col) {
            var ch = line.substr(col, 1)
            if (ch != ".") {
                var idx = to_int(ch) - 1
                if (idx >= 0 && idx < colors.size()) {
                    var c = colors[idx]
                    love.graphics.setColor(c[0], c[1], c[2])
                    love.graphics.rectangle("fill", sx + (aw - 1 - col) * scale, sy + row * scale, scale, scale)
                }
            }
        }
    }
}

